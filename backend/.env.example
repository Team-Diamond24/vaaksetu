# ===========================================
# Vaaksetu Backend Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values.

# Application
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# API Keys
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# OpenRouter API Key (optional - if not set, will use GEMINI_API_KEY directly)
# Get from: https://openrouter.ai/
OPENROUTER_API_KEY=

# VAD
VAD_ENERGY_THRESHOLD=2500

# Database
DATABASE_URL=sqlite:///./vaaksetu.db

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# WebSocket
WS_HEARTBEAT_INTERVAL=30
